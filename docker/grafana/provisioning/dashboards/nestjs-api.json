{
  "title": "NestJS API",
  "uid": "nestjs-api",
  "schemaVersion": 38,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s) — by route",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m])) by (method, route)",
          "legendFormat": "{{method}} {{route}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate (5xx) — by route",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[1m])) by (method, route)",
          "legendFormat": "{{method}} {{route}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "P50 / P90 / P99 Latency — by route",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[1m])) by (le, method, route))",
          "legendFormat": "p50 {{method}} {{route}}"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(http_request_duration_seconds_bucket[1m])) by (le, method, route))",
          "legendFormat": "p90 {{method}} {{route}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[1m])) by (le, method, route))",
          "legendFormat": "p99 {{method}} {{route}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Total Requests (counter)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(http_requests_total)",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "id": 5,
      "title": "Node.js Heap Used (bytes)",
      "type": "timeseries",
      "gridPos": { "x": 6, "y": 16, "w": 9, "h": 4 },
      "targets": [
        {
          "expr": "nodejs_heap_size_used_bytes",
          "legendFormat": "Heap Used"
        }
      ]
    },
    {
      "id": 6,
      "title": "Event Loop Lag (seconds)",
      "type": "timeseries",
      "gridPos": { "x": 15, "y": 16, "w": 9, "h": 4 },
      "targets": [
        {
          "expr": "nodejs_eventloop_lag_seconds",
          "legendFormat": "Event Loop Lag"
        }
      ]
    }
  ]
}
